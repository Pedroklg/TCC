# Copie para terraform.tfvars e ajuste. NÃO versione o terraform.tfvars.
my_ip_cidr = "SEU.IP.PUBLICO.AQUI/32"   # curl ifconfig.me  ->  acrescente /32
key_name   = "tcc-keypair"               # par de chaves EC2 já criado no console

# Opcionais — os defaults em variables.tf já seguem o Quadro 2 (instâncias de
# desempenho fixo). Descomente só para sobrescrever:
# region                 = "us-east-1"
# monolith_instance_type = "c5.large"  # 2 vCPU / 4 GB (base da equivalência)
# mysql_instance_type    = "m5.large"  # 2 vCPU / 8 GB
# lambda_memory_mb       = 1769        # ≈ 1 vCPU por invocação
